# Copy this file to .env.local and fill in your values.
# Never commit .env.local. It is listed in .gitignore.

# Supabase frontend config. Vite only exposes variables with the VITE_ prefix.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key_here

# Gemini API key is a Supabase Edge Function secret, not a frontend variable.
# Set it with:
# supabase secrets set GEMINI_API_KEY=your_key
